# =============================================================
# Variáveis de ambiente — Explorador Temporal de Imagens de Satélite
# Krassimire Iankov Djimov · 2301201 · Universidade Aberta
# =============================================================
#
# INSTRUÇÕES:
# 1. Copiar este ficheiro para .env.local (nunca commitar .env.local!)
# 2. Preencher as credenciais reais do Copernicus SentinelHub
# 3. O ficheiro .env.local já está no .gitignore
#
# COMO OBTER AS CREDENCIAIS:
# 1. Criar conta em https://identity.dataspace.copernicus.eu
# 2. Dashboard OAuth: https://shapps.dataspace.copernicus.eu/dashboard/#/account/settings
# 3. Criar um cliente OAuth2 — o Client ID começa por "sh-"
# =============================================================

# --- Copernicus SentinelHub — OAuth2 Client Credentials ---
COPERNICUS_CLIENT_ID=sh-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
COPERNICUS_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- URLs da API Copernicus (CORRIGIDAS em Maio 2026) ---
# NOTA: O catálogo genérico catalogue.dataspace.copernicus.eu/stac NÃO tem
# colecções Sentinel-2. O endpoint correcto é o SentinelHub Catalog API.
COPERNICUS_STAC_URL=https://sh.dataspace.copernicus.eu/api/v1/catalog/1.0.0
COPERNICUS_OGC_URL=https://sh.dataspace.copernicus.eu/ogc/wms
COPERNICUS_TOKEN_URL=https://identity.dataspace.copernicus.eu/auth/realms/CDSE/protocol/openid-connect/token

# --- Configuração Next.js ---
NEXT_PUBLIC_APP_NAME=Explorador Temporal de Imagens de Satélite
