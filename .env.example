# Application
NEXT_PUBLIC_APP_NAME="Explorador Temporal de Imagens de Satélite"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Copernicus Data Space Ecosystem - catalogue & rendering
CDSE_STAC_API_URL="https://stac.dataspace.copernicus.eu/v1"
CDSE_STAC_SEARCH_URL="https://stac.dataspace.copernicus.eu/v1/search"
CDSE_ODATA_API_URL="https://catalogue.dataspace.copernicus.eu/odata/v1"
CDSE_PROCESS_API_URL="https://sh.dataspace.copernicus.eu/process/v1"

# OAuth2 / Sentinel Hub authentication
CDSE_TOKEN_URL="https://identity.dataspace.copernicus.eu/auth/realms/CDSE/protocol/openid-connect/token"
CDSE_CLIENT_ID=""
CDSE_CLIENT_SECRET=""

# Project defaults
DEFAULT_COLLECTION="sentinel-2-l2a"
DEFAULT_MAX_CLOUD_COVER=20
DEFAULT_OUTPUT_WIDTH=768
DEFAULT_OUTPUT_HEIGHT=768
DEFAULT_PREVIEW_FORMAT="image/jpeg"
